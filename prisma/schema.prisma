generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Delivery {
  id           String   @id @default(cuid())
  event        String
  invoiceId    String?  // 👈 TEMPORARY nullable
  requestBody  String
  responseBody String
  statusCode   Int
  success      Boolean
  createdAt    DateTime @default(now())

  @@index([invoiceId])
}